{
  "_comment": "Schema Markup Templates for Local Service Business. Prices are OPTIONAL — omit the 'offers' block if client restricts pricing.",

  "LocalBusiness_MassageTherapy": {
    "@context": "https://schema.org",
    "@type": "MassageTherapy",
    "name": "{business_name}",
    "url": "https://{domain}",
    "telephone": "{phone}",
    "email": "{email}",
    "foundingDate": "{year}",
    "priceRange": "{$$}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{street}",
      "addressLocality": "{city}",
      "addressRegion": "{state}",
      "postalCode": "{zip}",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "{lat}",
      "longitude": "{lng}"
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
        "opens": "09:00",
        "closes": "20:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Sunday",
        "opens": "10:00",
        "closes": "18:00"
      }
    ],
    "sameAs": [
      "{google_business_url}",
      "{facebook_url}",
      "{instagram_url}"
    ],
    "areaServed": [
      { "@type": "City", "name": "{primary_city}" },
      { "@type": "City", "name": "{nearby_city_1}" },
      { "@type": "City", "name": "{nearby_city_2}" }
    ],
    "paymentAccepted": "Cash, Credit Card, HSA, FSA"
  },

  "Service_Page": {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "{service_name} in {city}",
    "url": "https://{domain}/services/{service-slug}",
    "provider": {
      "@type": "MassageTherapy",
      "name": "{business_name}",
      "telephone": "{phone}",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{street}",
        "addressLocality": "{city}",
        "addressRegion": "{state}",
        "postalCode": "{zip}",
        "addressCountry": "US"
      }
    },
    "areaServed": {
      "@type": "City",
      "name": "{city}"
    },
    "serviceType": "{service_name}"
  },

  "Article_Guide": {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{article_title}",
    "url": "https://{domain}/guides/{slug}",
    "author": {
      "@type": "Organization",
      "name": "{business_name}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{business_name}"
    }
  },

  "FAQPage": {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do I need to make an appointment?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We recommend booking in advance online at {booking_link} or by calling {phone}."
        }
      },
      {
        "@type": "Question",
        "name": "Do you accept insurance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, we accept medical insurance, auto insurance (PIP), and workers' compensation. Call us for details."
        }
      },
      {
        "@type": "Question",
        "name": "Where is {business_name} located?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "{business_name} is located at {address}. We serve clients throughout {service_area}."
        }
      }
    ]
  },

  "BreadcrumbList": {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://{domain}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Services",
        "item": "https://{domain}/services"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "{Service Name}",
        "item": "https://{domain}/services/{service-slug}"
      }
    ]
  }
}
